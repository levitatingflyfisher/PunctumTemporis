---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Apps"
  description="Free, open-source apps for families from [C3_NAME]."
>

<section class="hero" style="padding:4rem 1.5rem;">
  <div class="container">
    <p class="section-label" style="color:#c8a060;">Apps</p>
    <h1>Free apps for everyday family life.</h1>
    <p class="tagline">
      Every app is free, open source, and keeps your data on your device.
    </p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="card-grid">

      <!-- One Second A Day -->
      <div class="card">
        <p class="section-label" style="margin-bottom:0.4rem;">Video Journal</p>
        <h3><a href="/apps/video-journal" style="color:var(--color-navy);">One Second A Day</a></h3>
        <p>
          Capture one second of video every day and compile them into montage
          videos. Retro CRT aesthetic, local-first, no cloud required.
          Face recognition, GPS tagging, backup and restore.
        </p>
        <div style="margin-top:1.25rem;display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
          <span class="badge badge-stable">Android — Stable</span>
          <span class="badge badge-beta">iOS PWA — Beta</span>
        </div>
        <div style="margin-top:1.25rem;">
          <a href="/apps/video-journal" class="btn btn-primary" style="font-size:0.875rem;padding:0.5rem 1.2rem;">View App</a>
          <a href="/apps/video-journal/download" style="margin-left:1rem;font-size:0.875rem;">Download &rarr;</a>
        </div>
      </div>

      <!-- Placeholder -->
      <div class="card" style="border-style:dashed;background:var(--color-bg-alt);">
        <p class="section-label" style="margin-bottom:0.4rem;color:var(--color-text-muted);">Coming Soon</p>
        <h3 style="color:var(--color-text-muted);">More Apps</h3>
        <p>We are working on more tools for families. <a href="/contact">Let us know</a> what you need.</p>
      </div>

    </div>

    <div style="margin-top:4rem;padding-top:3rem;border-top:1px solid var(--color-border);">
      <h2 style="font-size:1.3rem;">All apps share the same principles</h2>
      <ul style="margin-top:1rem;color:var(--color-text-muted);">
        <li>Free to download and use — no fees, no in-app purchases</li>
        <li>Open source — code is publicly auditable</li>
        <li>Local-first — your data lives on your device, not our servers</li>
        <li>No account required — install and use immediately</li>
        <li>No analytics, no telemetry, no advertising</li>
      </ul>
    </div>
  </div>
</section>

</Layout>
